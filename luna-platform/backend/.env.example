# SQLite (dev default) — sync driver, easy pandas export
DATABASE_URL=sqlite:///./luna.db

# Production Postgres (use psycopg2-binary, sync URL):
# DATABASE_URL=postgresql://user:pass@host:5432/luna

JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://lindsay522.github.io
